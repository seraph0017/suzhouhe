# ===========================================
# AI Manga/Video Production Pipeline System
# Environment Configuration
# ===========================================

# -------------------------------------------
# Application Settings
# -------------------------------------------
APP_NAME="AI Manga Pipeline"
APP_ENV=development
DEBUG=True

# -------------------------------------------
# Database Configuration (PostgreSQL)
# -------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=suzhou
DATABASE_USER=suzhou
DATABASE_PASSWORD=suzhou_dev_password
DATABASE_URL=postgresql://suzhou:suzhou_dev_password@localhost:5432/suzhou

# For local development with SQLite (alternative)
# DATABASE_URL=sqlite:///./suzhou_dev.db

# -------------------------------------------
# Security Settings
# -------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------------------------------
# MinIO / S3 Object Storage
# -------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=suzhou_admin
MINIO_SECRET_KEY=suzhou_dev_secret
MINIO_BUCKET=assets
MINIO_SECURE=false

# AWS S3 (alternative for production)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# S3_BUCKET=

# -------------------------------------------
# CORS Settings
# -------------------------------------------
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# -------------------------------------------
# File Upload Settings
# -------------------------------------------
MAX_UPLOAD_SIZE_MB=100
UPLOAD_DIR=./uploads

# -------------------------------------------
# Default AI Model Settings
# -------------------------------------------
DEFAULT_LLM_PROVIDER=openai
DEFAULT_IMAGE_PROVIDER=openai
DEFAULT_VIDEO_PROVIDER=openai
DEFAULT_TTS_PROVIDER=openai

# -------------------------------------------
# Logging
# -------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
