# ============================================
# Suzhou AI Pipeline - Environment Configuration
# ============================================

# --------------------------------------------
# Application Settings
# --------------------------------------------
APP_NAME=suzhou
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# --------------------------------------------
# Database Configuration (PostgreSQL)
# --------------------------------------------
DATABASE_URL=postgresql://suzhou:suzhou123@localhost:5432/suzhou

# --------------------------------------------
# Redis Configuration (for ARQ + WebSocket)
# --------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# --------------------------------------------
# MinIO Storage Configuration (S3-compatible)
# --------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=suzhou-assets
MINIO_SECURE=false

# --------------------------------------------
# JWT Authentication
# --------------------------------------------
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --------------------------------------------
# OpenAI Provider Configuration
# --------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_LLM_MODEL=gpt-4
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_TTS_MODEL=tts-1

# --------------------------------------------
# Anthropic Provider Configuration
# --------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --------------------------------------------
# Default Provider Selection
# --------------------------------------------
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_IMAGE_PROVIDER=openai
DEFAULT_TTS_PROVIDER=openai
DEFAULT_VIDEO_PROVIDER=runway
DEFAULT_BGM_PROVIDER=muse-net

# --------------------------------------------
# WebSocket Configuration
# --------------------------------------------
WS_MESSAGE_QUEUE_SIZE=1000
WS_HEARTBEAT_INTERVAL=30

# --------------------------------------------
# ARQ Worker Configuration
# --------------------------------------------
ARQ_JOB_TIMEOUT=600
ARQ_MAX_TRIES=3
ARQ_RETRY_DELAY=5

# --------------------------------------------
# CORS Configuration
# --------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# --------------------------------------------
# Logging Configuration
# --------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
